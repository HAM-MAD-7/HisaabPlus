@page
@model HisaabPlus.Web.Pages.Suppliers.IndexModel
@{
}

<div class="page-container">
    <div class="page-header">
        <h1>Suppliers</h1>
        <a asp-page="/Suppliers/Add">+ Add New Supplier</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <p>@Model.ErrorMessage</p>
        </div>
    }

    @if (Model.Suppliers != null && Model.Suppliers.Any(s => s.TotalBalance > 0))
    {
        <div class="alert alert-danger mt-20">
            <p>⚠️ <strong>You owe @Model.Suppliers.Count(s => s.TotalBalance > 0) supplier(s) money!</strong></p>
        </div>
    }

    @if (Model.Suppliers != null && Model.Suppliers.Count > 0)
    {
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Supplier ID</th>
                        <th>Supplier Name</th>
                        <th>Phone Number</th>
                        <th>Company Name</th>
                        <th>Total Balance</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var supplier in Model.Suppliers)
                    {
                        <tr style="@(supplier.TotalBalance > 0 ? "background-color: #FFE5E5;" : "")">
                            <td>@supplier.SupplierId</td>
                            <td>@supplier.SupplierName</td>
                            <td>@supplier.PhoneNumber</td>
                            <td>@supplier.CompanyName</td>
                            <td>
                                @if (supplier.TotalBalance > 0)
                                {
                                    <span class="text-warning">Rs. @supplier.TotalBalance</span>
                                }
                                else
                                {
                                    <span>Rs. @supplier.TotalBalance</span>
                                }
                            </td>
                            <td>
                                <div class="action-links">
                                    <a asp-page="/Suppliers/Detail" asp-route-supplierId="@supplier.SupplierId">Detail</a>
                                    <a asp-page="/Suppliers/Edit" asp-route-supplierId="@supplier.SupplierId">Edit</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            <p>No suppliers found.</p>
        </div>
    }
</div>