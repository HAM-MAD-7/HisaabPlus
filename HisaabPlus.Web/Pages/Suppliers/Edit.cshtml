@page
@model HisaabPlus.Web.Pages.Suppliers.EditModel
@{
}

<div class="page-container">
    <div class="form-container">
        <h1>Edit Supplier</h1>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">
                <p>@Model.ErrorMessage</p>
            </div>
        }

        <form method="post" asp-antiforgery="true">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Input.SupplierName"></label>
                <input asp-for="Input.SupplierName" />
                <span asp-validation-for="Input.SupplierName"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.PhoneNumber"></label>
                <input type="tel" asp-for="Input.PhoneNumber" />
                <span asp-validation-for="Input.PhoneNumber"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.CompanyName"></label>
                <input asp-for="Input.CompanyName" />
                <span asp-validation-for="Input.CompanyName"></span>
            </div>

            <input type="hidden" asp-for="Input.SupplierId" />

            <div class="form-actions">
                <button type="submit">Submit</button>
                <a asp-page="/Suppliers/Index">Cancel</a>
            </div>
        </form>
    </div>
</div>