@page
@model HisaabPlus.Web.Pages.StockPurchase.RecordPaymentModel
@{
}
<div>
    <h1>Record Payment</h1>
</div>
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div>
        <p style="color:red">@Model.ErrorMessage</p>
    </div>
}
<form method="post" asp-antiforgery="true">
    @Html.AntiForgeryToken()
    <div>
        <label asp-for="Input.Amount"></label>
        <input type="number" step="0.01" asp-for="Input.Amount"/>
        <span asp-validation-for="Input.Amount"></span>
    </div>
    <div>
        <label asp-for="Input.Notes"></label>
        <input asp-for="Input.Notes" />
        <span asp-validation-for="Input.Notes"></span>
    </div>
    <div>
        <input type="hidden" asp-for="Input.SupplierId"/>
        <button type="submit">Submit</button>
        <a asp-page="/Suppliers/Detail" asp-route-supplierId="@Model.Input.SupplierId">Cancel</a>
    </div>
</form>