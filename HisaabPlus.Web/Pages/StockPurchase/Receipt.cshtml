@page
@model HisaabPlus.Web.Pages.StockPurchase.ReceiptModel
@{
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div>
        <p style="color:red">@Model.ErrorMessage</p>
    </div>
}
<div>
    <h1>Purchase Info</h1>
    <p><strong>Purchase Id:</strong> @Model.StockPurchase.PurchaseId</p>
    <p><strong>Supplier Id:</strong> @Model.StockPurchase.SupplierId</p>
    <p><strong>Supplier Name:</strong> @Model.StockPurchase.SupplierName</p>
    <p><strong>Purchase Date:</strong> @Model.StockPurchase.PurchaseDate</p>
</div>
<br />
<div>
    <h1>Product Record</h1>
</div>
@if (Model.StockPurchase.Items != null && Model.StockPurchase.Items.Count > 0)
{
    <table>
        <thead>
            <tr>
                <th>Product Name</th>
                <th>Quantity</th>
                <th>Unit Price</th>
                <th>Total Price</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.StockPurchase.Items)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitPrice</td>
                    <td>@item.TotalPrice</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div>
        <p>No stock purchase receipt found!</p>
    </div>
}
<br />
<div>
    <h1>Purchase Summary</h1>
    <p><strong>Total Amount:</strong> @Model.StockPurchase.TotalAmount</p>
    <p><strong>Paid Amount:</strong> @Model.StockPurchase.PaidAmount</p>
    <p><strong>Remaining Amount:</strong> @Model.StockPurchase.RemainingAmount</p>
    <p><strong>Payment Type:</strong> @Model.StockPurchase.PaymentType</p>
</div>
<br />
<div>
    <a asp-page="/StockPurchase/Index">Back to purchases</a>
</div>