@page
@model HisaabPlus.Web.Pages.StockPurchase.IndexModel
@{
}

<div class="page-container">
    <div class="page-header">
        <h1>Stock Purchases</h1>
        <a asp-page="/StockPurchase/Create">+ Record New Purchase</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <p>@Model.ErrorMessage</p>
        </div>
    }

    @if (Model.MonthlyStock != null && Model.MonthlyStock.Count > 0)
    {
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Purchase ID</th>
                        <th>Supplier ID</th>
                        <th>Supplier Name</th>
                        <th>Purchase Date</th>
                        <th>Total Amount</th>
                        <th>Paid Amount</th>
                        <th>Remaining Amount</th>
                        <th>Payment Type</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.MonthlyStock)
                    {
                        <tr>
                            <td>@item.PurchaseId</td>
                            <td>@item.SupplierId</td>
                            <td>@item.SupplierName</td>
                            <td>@item.PurchaseDate.ToShortDateString()</td>
                            <td>Rs. @item.TotalAmount</td>
                            <td>Rs. @item.PaidAmount</td>
                            <td>Rs. @item.RemainingAmount</td>
                            <td>@item.PaymentType</td>
                            <td>
                                <div class="action-links">
                                    <a asp-page="/StockPurchase/Receipt" asp-route-purchaseId="@item.PurchaseId">Receipt</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            <p>No monthly stock purchases found.</p>
        </div>
    }
</div>