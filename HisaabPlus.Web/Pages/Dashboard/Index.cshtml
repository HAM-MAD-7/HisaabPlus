@page
@model HisaabPlus.Web.Pages.Dashboard.IndexModel
@{
    var today = DateTime.UtcNow;
}

<div class="dashboard-container">
    <h1 class="page-title">Dashboard</h1>

    @if (@Model.Dashboard.LowStockCount > 0 || @Model.Dashboard.TotalCustomerBalance > 0 || @Model.Dashboard.TotalSupplierBalance > 0)
    {
        <div class="alerts-container">
            <h2 class="alerts-title">⚠️ Critical Alerts</h2>

            <div class="alerts-grid">
                @if (@Model.Dashboard.LowStockCount > 0)
                {
                    <div class="alert-card alert-warning">
                        <div class="alert-icon">📦</div>
                        <div class="alert-content">
                            <h3>Low Stock Products</h3>
                            <p class="alert-number">@Model.Dashboard.LowStockCount Products</p>
                            <a asp-page="/Products/Index" class="alert-link">View Products →</a>
                        </div>
                    </div>
                }

                @if (@Model.Dashboard.TotalCustomerBalance > 0)
                {
                    <div class="alert-card alert-danger">
                        <div class="alert-icon">👥</div>
                        <div class="alert-content">
                            <h3>Customer Payments Due</h3>
                            <p class="alert-number">Rs. @Model.Dashboard.TotalCustomerBalance</p>
                            <a asp-page="/Customers/Index" class="alert-link">Collect Payment →</a>
                        </div>
                    </div>
                }

                @if (@Model.Dashboard.TotalSupplierBalance > 0)
                {
                    <div class="alert-card alert-info">
                        <div class="alert-icon">🏭</div>
                        <div class="alert-content">
                            <h3>Supplier Payments Due</h3>
                            <p class="alert-number">Rs. @Model.Dashboard.TotalSupplierBalance</p>
                            <a asp-page="/Suppliers/Index" class="alert-link">Pay Suppliers →</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <div class="dashboard-grid">
 
        <div class="card">
            <div class="card-header">Today's Date</div>
            <div class="card-body">
                <p class="metric-value">@Model.Dashboard.TodayDate.ToShortDateString()</p>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Today's Total Sales</div>
            <div class="card-body">
                <p class="metric-value text-primary">Rs. @Model.Dashboard.TodayTotalSales</p>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Today's Cash Sales</div>
            <div class="card-body">
                <p class="metric-value text-success">Rs. @Model.Dashboard.TodayCashSales</p>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Today's Loan Sales</div>
            <div class="card-body">
                <p class="metric-value text-accent">Rs. @Model.Dashboard.TodayLoanSales</p>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Total Customer Balance</div>
            <div class="card-body">
                <p class="metric-value text-warning">Rs. @Model.Dashboard.TotalCustomerBalance</p>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Total Supplier Balance</div>
            <div class="card-body">
                <p class="metric-value text-warning">Rs. @Model.Dashboard.TotalSupplierBalance</p>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Today's Estimated Profit</div>
            <div class="card-body">
                <p class="metric-value text-success">Rs. @Model.Dashboard.TodayEstimatedProfit.ToString("F2")</p>
            </div>
        </div>

        @if (@Model.Dashboard.LowStockCount > 0)
        {
            <div class="card card-alert">
                <div class="card-header">⚠️ Low Stock Count</div>
                <div class="card-body">
                    <p class="metric-value text-warning">@Model.Dashboard.LowStockCount Products</p>
                </div>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger mt-20">
            <p>@Model.ErrorMessage</p>
        </div>
    }

    <div class="mt-20">
        <a asp-page="/Dashboard/Report" asp-route-month="@today.Month" asp-route-year="@today.Year" class="btn btn-primary">View Monthly Report</a>
    </div>
</div>