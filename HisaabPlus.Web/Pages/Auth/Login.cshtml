@page
@model HisaabPlus.Web.Pages.Auth.LoginModel
@{
}

<div class="page-container">
    <div class="form-container" style="max-width: 400px;">
        <h1>Shop Owner Login</h1>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">
                <p>@Model.ErrorMessage</p>
            </div>
        }

        <form method="post" asp-antiforgery="true">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Input.PhoneNumber"></label>
                <input type="tel" asp-for="Input.PhoneNumber" />
                <span asp-validation-for="Input.PhoneNumber"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password"></label>
                <input type="password" asp-for="Input.Password" />
                <span asp-validation-for="Input.Password"></span>
            </div>

            <div class="form-actions">
                <button type="submit">Login</button>
                <a asp-page="/Index">Cancel</a>
            </div>
        </form>
    </div>
</div>