@page
@model HisaabPlus.Web.Pages.Customers.RecordPaymentModel
@{
}

<div class="page-container">
    <div class="form-container">
        <h1>Record Payment</h1>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">
                <p>@Model.ErrorMessage</p>
            </div>
        }

        <form method="post" asp-antiforgery="true">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Input.Amount"></label>
                <input type="number" step="0.01" asp-for="Input.Amount" />
                <span asp-validation-for="Input.Amount"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Notes"></label>
                <input asp-for="Input.Notes" />
                <span asp-validation-for="Input.Notes"></span>
            </div>

            <input type="hidden" asp-for="Input.CustomerId" />

            <div class="form-actions">
                <button type="submit">Submit</button>
                <a asp-page="/Customers/Detail" asp-route-customerId="@Model.Input.CustomerId">Cancel</a>
            </div>
        </form>
    </div>
</div>