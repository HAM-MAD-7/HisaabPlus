@page
@model HisaabPlus.Web.Pages.Customers.IndexModel
@{
}

<div class="page-container">
    <div class="page-header">
        <h1>Customers</h1>
        <a asp-page="/Customers/Add">+ Add New Customer</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <p>@Model.ErrorMessage</p>
        </div>
    }

    @if (Model.Customers != null && Model.Customers.Any(c => c.TotalBalance > 0))
    {
        <div class="alert alert-danger mt-20">
            <p>⚠️ <strong>@Model.Customers.Count(c => c.TotalBalance > 0) customer(s) owe money!</strong></p>
        </div>
    }

    @if (Model.Customers != null && Model.Customers.Count > 0)
    {
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Phone Number</th>
                        <th>Total Balance</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Customers)
                    {
                        <tr style="@(item.TotalBalance > 0 ? "background-color: #FFE5E5;" : "")">
                            <td>@item.FullName</td>
                            <td>@item.PhoneNumber</td>
                            <td>
                                @if (item.TotalBalance > 0)
                                {
                                    <span class="text-warning">Rs. @item.TotalBalance</span>
                                }
                                else
                                {
                                    <span>Rs. @item.TotalBalance</span>
                                }
                            </td>
                            <td>
                                <div class="action-links">
                                    <a asp-page="/Customers/Detail" asp-route-customerId="@item.CustomerId">Detail</a>
                                    <a asp-page="/Customers/Edit" asp-route-customerId="@item.CustomerId">Edit</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            <p>No customers found.</p>
        </div>
    }
</div>