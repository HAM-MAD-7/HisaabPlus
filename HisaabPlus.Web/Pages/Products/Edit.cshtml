@page
@model HisaabPlus.Web.Pages.Products.EditModel
@{
}

<div class="page-container">
    <div class="form-container">
        <h1>Edit Product</h1>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">
                <p>@Model.ErrorMessage</p>
            </div>
        }

        <form method="post" asp-antiforgery="true">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Input.ProductName"></label>
                <input asp-for="Input.ProductName" />
                <span asp-validation-for="Input.ProductName"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Category"></label>
                <input asp-for="Input.Category" />
                <span asp-validation-for="Input.Category"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.PurchasePrice"></label>
                <input type="number" step="0.01" asp-for="Input.PurchasePrice" />
                <span asp-validation-for="Input.PurchasePrice"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.SellingPrice"></label>
                <input type="number" step="0.01" asp-for="Input.SellingPrice" />
                <span asp-validation-for="Input.SellingPrice"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.CurrentStock"></label>
                <input type="number" step="0.01" asp-for="Input.CurrentStock" />
                <span asp-validation-for="Input.CurrentStock"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Unit"></label>
                <input asp-for="Input.Unit" />
                <span asp-validation-for="Input.Unit"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.LowStockLimit"></label>
                <input type="number" step="0.01" asp-for="Input.LowStockLimit" />
                <span asp-validation-for="Input.LowStockLimit"></span>
            </div>

            <input type="hidden" asp-for="Input.ProductId" />

            <div class="form-actions">
                <button type="submit">Submit</button>
                <a asp-page="/Products/Index">Cancel</a>
            </div>
        </form>
    </div>
</div>