@page
@model HisaabPlus.Web.Pages.Products.IndexModel
@{
}
<a asp-page="/Products/Add">Add New Product</a>
<table>
    <thead>
        <tr>
            <th>Product Name</th>
            <th>Category</th>
            <th>Selling Price</th>
            <th>Stock</th>
            <th>Unit</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model.productResponses)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Category</td>
                <td>@item.SellingPrice</td>
                <td>
                    @item.CurrentStock
                    @if (item.CurrentStock <= item.LowStockLimit)
                    {
                        <span style="color:red">⚠ Low Stock</span>
                    }
                </td>
                <td>@item.Unit</td>
                <td>
                    <a asp-page="/Products/Edit" asp-route-productId="@item.ProductId">Edit</a>
                    <form method="post" asp-page-handler="Delete" style="display:inline;">
                        <input type="hidden" name="productId" value="@item.ProductId"/>
                        <button type="submit">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>