@page
@model HisaabPlus.Web.Pages.Products.IndexModel
@{
}

<div class="page-container">
    <div class="page-header">
        <h1>Products</h1>
        <a asp-page="/Products/Add">+ Add New Product</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <p>@Model.ErrorMessage</p>
        </div>
    }

    @if (Model.Products != null && Model.Products.Any(p => p.CurrentStock <= p.LowStockLimit))
    {
        <div class="alert alert-danger mt-20">
            <p>⚠️ <strong>@Model.Products.Count(p => p.CurrentStock <= p.LowStockLimit) product(s) are low on stock!</strong></p>
        </div>
    }

    @if (Model.Products != null && Model.Products.Count > 0)
    {
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>Purchase Price</th>
                        <th>Selling Price</th>
                        <th>Current Stock</th>
                        <th>Low Stock Limit</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model.Products)
                    {
                        <tr style="@(product.CurrentStock <= product.LowStockLimit ? "background-color: #FFE5E5;" : "")">
                            <td>@product.ProductName</td>
                            <td>@product.Category</td>
                            <td>Rs. @product.PurchasePrice</td>
                            <td>Rs. @product.SellingPrice</td>
                            <td>@product.CurrentStock</td>
                            <td>@product.LowStockLimit</td>
                            <td>
                                @if (product.IsActive)
                                {
                                    <span class="text-success">Active</span>
                                }
                                else
                                {
                                    <span class="text-warning">Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="action-links">
                                    <a asp-page="/Products/Edit" asp-route-productId="@product.ProductId">Edit</a>
                                    @if (product.IsActive)
                                    {
                                        <button type="button" class="action-links delete" onclick="showConfirmModal('deactivate', @product.ProductId)">Deactivate</button>
                                        <form id="deactivateForm_@product.ProductId" method="post" asp-page-handler="Delete" style="display:none;">
                                            <input type="hidden" name="productId" value="@product.ProductId" />
                                        </form>
                                    }
                                    else
                                    {
                                        <button type="button" class="action-links delete" onclick="showConfirmModal('reactivate', @product.ProductId)">Reactivate</button>
                                        <form id="reactivateForm_@product.ProductId" method="post" asp-page-handler="Reactivate" style="display:none;">
                                            <input type="hidden" name="productId" value="@product.ProductId" />
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            <p>No products found.</p>
        </div>
    }
</div>
<script>
    function showConfirmModal(action, productId) {
        const modal = document.getElementById('confirmModal');
        const message = document.getElementById('confirmMessage');
        const confirmBtn = document.getElementById('confirmBtn');

        if (action === 'deactivate') {
            message.textContent = 'Are you sure you want to deactivate this product?';
            confirmBtn.onclick = function() {
                document.getElementById('deactivateForm_' + productId).submit();
            };
        } else if (action === 'reactivate') {
            message.textContent = 'Are you sure you want to reactivate this product?';
            confirmBtn.onclick = function() {
                document.getElementById('reactivateForm_' + productId).submit();
            };
        }

        modal.classList.add('show');
    }

    function closeConfirmModal() {
        document.getElementById('confirmModal').classList.remove('show');
    }
</script>

<div id="confirmModal" class="modal">
    <div class="modal-content">
        <h3>⚠️ Confirm Action</h3>
        <p id="confirmMessage"></p>
        <div class="modal-actions">
            <button class="confirm-btn" id="confirmBtn">Confirm</button>
            <button class="cancel-btn" onclick="closeConfirmModal()">Cancel</button>
        </div>
    </div>
</div>