@page
@model HisaabPlus.Web.Pages.Sales.IndexModel
@{
}

<div class="page-container">
    <div class="page-header">
        <h1>Sales</h1>
        <a asp-page="/Sales/Create">+ Create New Sale</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <p>@Model.ErrorMessage</p>
        </div>
    }

    @if (Model.Sales != null && Model.Sales.Count > 0)
    {
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Sale ID</th>
                        <th>Customer Name</th>
                        <th>Payment Type</th>
                        <th>Total Amount</th>
                        <th>Paid Amount</th>
                        <th>Remaining Amount</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Sales)
                    {
                        <tr>
                            <td>@item.SaleId</td>
                            <td>@item.CustomerName</td>
                            <td>@item.PaymentType</td>
                            <td>Rs. @item.TotalAmount</td>
                            <td>Rs. @item.PaidAmount</td>
                            <td>Rs. @item.RemainingAmount</td>
                            <td>
                                <div class="action-links">
                                    <a asp-page="/Sales/Receipt" asp-route-saleId="@item.SaleId">Receipt</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            <p>No sales found.</p>
        </div>
    }
</div>