@page
@model HisaabPlus.Web.Pages.Sales.ReceiptModel
@{
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div>
        <p style="color:red">@Model.ErrorMessage</p>
    </div>
}
<div>
    <h1>Sale Info</h1>
    <p>@Model.Sale.SaleId</p>
    <p>@Model.Sale.SaleDate</p>
    <p>@Model.Sale.CustomerName</p>
</div>
<table>
    <thead>
        <tr>
            <th>Product Name</th>
            <th>Quantity</th>
            <th>Unit Price</th>
            <th>Total Price</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model.Sale.Items)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Quantity</td>
                <td>@item.UnitPrice</td>
                <td>@item.TotalPrice</td>
            </tr>
        }
    </tbody>
</table>
<br />
<div>
    <h1>Sale Summary</h1>
    <p>@Model.Sale.TotalAmount</p>
    <p>@Model.Sale.PaidAmount</p>
    <p>@Model.Sale.RemainingAmount</p>
    <p>@Model.Sale.PaymentType</p>
</div>
<br />
<div>
    <a asp-page="/Sales/Index">Back to Sales</a>
</div>
