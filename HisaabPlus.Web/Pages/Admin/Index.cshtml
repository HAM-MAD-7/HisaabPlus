@page
@model HisaabPlus.Web.Pages.Admin.IndexModel
@{
}

<div class="page-container">
    <div class="page-header">
        <h1>Admin - Manage Shops</h1>
        <a asp-page="/Admin/RegisterShop">+ Register New Shop</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <p>@Model.ErrorMessage</p>
        </div>
    }

    @if (Model.Shops != null && Model.Shops.Any(s => s.DaysRemaining <= 3 && s.DaysRemaining > 0))
    {
        <div class="alert alert-danger mt-20">
            <p>⚠️ <strong>@Model.Shops.Count(s => s.DaysRemaining <= 3 && s.DaysRemaining > 0) shop(s) have subscriptions expiring soon!</strong></p>
        </div>
    }

    @if (Model.Shops != null && Model.Shops.Count > 0)
    {
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Shop Name</th>
                        <th>Owner Name</th>
                        <th>Phone Number</th>
                        <th>Status</th>
                        <th>Subscription End Date</th>
                        <th>Days Remaining</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var items in Model.Shops)
                    {
                        <tr style="@(items.DaysRemaining <= 3 && items.DaysRemaining > 0 ? "background-color: #FFE5E5;" : "")">
                            <td>@items.ShopName</td>
                            <td>@items.OwnerName</td>
                            <td>@items.PhoneNumber</td>
                            <td>
                                @if (items.IsActive)
                                {
                                    <span class="text-success">Active</span>
                                }
                                else
                                {
                                    <span class="text-warning">Locked</span>
                                }
                            </td>
                            <td>@items.SubscriptionEndDate.ToShortDateString()</td>
                            <td>
                                @if (items.DaysRemaining > 0)
                                {
                                    <span class="text-success">@items.DaysRemaining days</span>
                                }
                                else
                                {
                                    <span class="text-warning">Expired</span>
                                }
                            </td>
                            <td>
                                <div class="action-links">
                                    @if (items.IsActive == true)
                                    {
                                        <button type="button" class="action-links delete" onclick="showConfirmModal('lock', @items.ShopId)">Lock Shop</button>

                                        <form id="lockForm_@items.ShopId" method="post" asp-page-handler="Lock" style="display:none;">
                                            <input type="hidden" name="shopId" value="@items.ShopId" />
                                        </form>
                                    }
                                    else
                                    {
                                        <button type="button" style="background-color: var(--success);" onclick="showConfirmModal('unlock', @items.ShopId)">Unlock Shop</button>

                                        <form id="unlockForm_@items.ShopId" method="post" asp-page-handler="Unlock" style="display:none;">
                                            <input type="hidden" name="shopId" value="@items.ShopId" />
                                        </form>
                                    }
                                    <a asp-page="/Admin/AddSubscription" asp-route-shopId="@items.ShopId">Add Subscription</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            <p>No shops found!</p>
        </div>
    }
</div>
<script>
    function showConfirmModal(action, shopId) {
        const modal = document.getElementById('confirmModal');
        const message = document.getElementById('confirmMessage');
        const confirmBtn = document.getElementById('confirmBtn');

        if (action === 'lock') {
            message.textContent = 'Are you sure you want to lock this shop?';
            confirmBtn.onclick = function() {
                document.getElementById('lockForm_' + shopId).submit();
            };
        } else if (action === 'unlock') {
            message.textContent = 'Are you sure you want to unlock this shop?';
            confirmBtn.onclick = function() {
                document.getElementById('unlockForm_' + shopId).submit();
            };
        }

        modal.classList.add('show');
    }

    function closeConfirmModal() {
        document.getElementById('confirmModal').classList.remove('show');
    }
</script>

<div id="confirmModal" class="modal">
    <div class="modal-content">
        <h3>⚠️ Confirm Action</h3>
        <p id="confirmMessage"></p>
        <div class="modal-actions">
            <button class="confirm-btn" id="confirmBtn">Confirm</button>
            <button class="cancel-btn" onclick="closeConfirmModal()">Cancel</button>
        </div>
    </div>
</div>