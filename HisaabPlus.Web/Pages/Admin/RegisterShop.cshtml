@page
@model HisaabPlus.Web.Pages.Admin.RegisterShopModel
@{
}

<div class="page-container">
    <div class="form-container">
        <h1>Register New Shop</h1>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">
                <p>@Model.ErrorMessage</p>
            </div>
        }

        <form method="post" asp-antiforgery="true">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Input.ShopName"></label>
                <input asp-for="Input.ShopName" />
                <span asp-validation-for="Input.ShopName"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.OwnerName"></label>
                <input asp-for="Input.OwnerName" />
                <span asp-validation-for="Input.OwnerName"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.PhoneNumber"></label>
                <input type="tel" asp-for="Input.PhoneNumber" />
                <span asp-validation-for="Input.PhoneNumber"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Address"></label>
                <input asp-for="Input.Address" />
                <span asp-validation-for="Input.Address"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Email"></label>
                <input type="email" asp-for="Input.Email" />
                <span asp-validation-for="Input.Email"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password"></label>
                <input type="password" asp-for="Input.Password" />
                <span asp-validation-for="Input.Password"></span>
            </div>

            <div class="form-actions">
                <button type="submit">Submit</button>
                <a asp-page="/Admin/Index">Cancel</a>
            </div>
        </form>
    </div>
</div>